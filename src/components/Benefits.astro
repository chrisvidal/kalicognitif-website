---
const benefits = [
  {
    titre: "Concentration",
    description:
      "Ancrage dans l'instant présent, focus mental sous contrainte physique.",
  },
  {
    titre: "Gestion du stress",
    description:
      "Défoulement structuré et apprentissage du calme sous pression.",
  },
  {
    titre: "Confiance en soi",
    description: "Progression technique visible, sentiment de maîtrise.",
  },
  {
    titre: "Cohésion d'équipe",
    description: "Exercices en binôme qui créent du lien entre collègues.",
  },
  {
    titre: "Coordination",
    description:
      "Travail moteur et précision gestuelle, transférables au quotidien.",
  },
  {
    titre: "Fun",
    description:
      "Une pratique conviviale et énergisante, loin de la routine du sport en salle.",
  },
];
---

<section class="px-6 py-20 sm:px-10 lg:px-16">
  <div class="mx-auto max-w-6xl">
    <h2
      class="text-center font-heading text-3xl font-extrabold text-ink sm:text-4xl"
    >
      Les bénéfices pour vos équipes
    </h2>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        benefits.map((benefit, index) => (
          <div class="rounded-xl bg-paper p-6 shadow-sm">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-crimson font-heading font-bold text-paper">
              {index + 1}
            </span>
            <h3 class="mt-4 font-heading text-lg font-bold text-ink">
              {benefit.titre}
            </h3>
            <p class="mt-2 text-sm text-ink/70">{benefit.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
