---
const items = [
  {
    titre: "Travail à mains nues, gants ou bâtons de mousse",
    description:
      "Des outils pédagogiques progressifs, fournis par le coach et adaptés au niveau de chaque participant.",
  },
  {
    titre: "Un vrai travail cardio",
    description:
      "La boxe intuitive (voir vidéo ci-dessous) apporte intensité et dépense physique, dans une approche technique et cardio.",
  },
  {
    titre: "Une initiation à l'auto-défense",
    description:
      "Le Kali transmet des réflexes de protection simples, applicables et rassurants au quotidien.",
  },
];
---

<section class="bg-mist px-6 py-20 sm:px-10 lg:px-16">
  <div class="mx-auto max-w-4xl">
    <h2
      class="text-center font-heading text-3xl font-extrabold text-ink sm:text-4xl"
    >
      Le contenu des sessions
    </h2>

    <ul class="mt-12 space-y-6">
      {
        items.map((item) => (
          <li class="flex gap-4 rounded-xl bg-mist p-6">
            <span class="mt-2 h-2 w-2 flex-none rounded-full bg-crimson" />
            <div>
              <h3 class="font-heading text-lg font-bold text-ink">
                {item.titre}
              </h3>
              <p class="mt-2 text-sm text-ink/70">{item.description}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
