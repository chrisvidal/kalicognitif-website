---
import VideoEmbed from "./VideoEmbed.astro";

interface Video {
  id: string;
  titre: string;
  description: string;
}

interface Props {
  videos: Video[];
}

const { videos } = Astro.props;
---

<section class="px-6 py-20 sm:px-10 lg:px-16">
  <div class="mx-auto max-w-6xl">
    <h2
      class="text-center font-heading text-3xl font-extrabold text-ink sm:text-4xl"
    >
      Kali Cognitif en vidéo
    </h2>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        videos.map((video) => (
          <VideoEmbed
            youtubeId={video.id}
            titre={video.titre}
            description={video.description}
          />
        ))
      }
    </div>
  </div>
</section>
